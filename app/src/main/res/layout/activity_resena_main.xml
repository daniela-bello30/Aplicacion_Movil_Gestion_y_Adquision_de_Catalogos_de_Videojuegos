<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- 1. DATO: Nombre de Usuario (Username) -->
    <!-- Texto más grande y con un color principal -->
    <TextView
        android:id="@+id/tvUsername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        tools:text="\@jersontq" />

    <!-- 2. DATO: Correo Electrónico (Gmail) -->
    <!-- Un poco más de espacio y texto más grande -->
    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:textSize="18sp"
        android:textColor="@android:color/darker_gray"
        tools:text="jersontunquequispe@gmail.com" />

    <!-- 3. DATO: Fecha de Nacimiento -->
    <!-- Mismo estilo que el email para consistencia -->
    <TextView
        android:id="@+id/tvFechaNacimiento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textSize="18sp"
        android:textColor="@android:color/darker_gray"
        tools:text="Nacimiento: 01/01/2000" />

    <!-- Botón para ver las reseñas -->
    <!-- Más grande y con más espacio superior -->
    <Button
        android:id="@+id/btnVerResenas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ver mis reseñas"
        android:layout_marginTop="40dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:textSize="18sp"/>

</LinearLayout>