<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        tools:context=".CrearActivity">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CREAR NUEVO JUEGO"
            android:textAlignment="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:paddingTop="40dp"
            android:paddingBottom="20dp" />

        <!-- ID del Juego -->
        <EditText
            android:id="@+id/etCrearId"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Ingresa el ID del juego"
            android:inputType="text"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:background="@color/cardview_shadow_start_color" />

        <!-- Nombre -->
        <EditText
            android:id="@+id/etCrearNombre"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Ingresa el nombre del juego"
            android:inputType="text"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:background="@color/cardview_shadow_start_color" />

        <!-- Descripción -->
        <EditText
            android:id="@+id/etCrearDescripcion"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Ingresa la descripción del juego"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:background="@color/cardview_shadow_start_color" />

        <!-- Precio -->
        <EditText
            android:id="@+id/etCrearPrecio"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Ingresa el precio (ej: 59.99)"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:background="@color/cardview_shadow_start_color" />

        <!-- Fecha de Lanzamiento -->
        <EditText
            android:id="@+id/etCrearFechaLanz"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Fecha (YYYY-MM-DD)"
            android:inputType="date"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:background="@color/cardview_shadow_start_color" />

        <!-- Botón Crear -->
        <Button
            android:id="@+id/btnCrear"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CREAR JUEGO"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
