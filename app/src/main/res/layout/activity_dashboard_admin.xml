<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp">

    <!-- Título del Dashboard -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dashboard de Administrador"
        android:textSize="20sp"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp" />

    <!-- Logo -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="230dp"
        android:layout_height="233dp"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="60dp"
        android:contentDescription="Logo Arcadia X-One"
        android:src="@drawable/logo_dam" />

    <!-- Botón Gestión de Usuarios -->
    <Button
        android:id="@+id/btnGestionUsuarios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestión de Usuarios"
        android:textSize="16sp"
        android:textColor="#000000"
        android:background="@drawable/button_outline"
        android:layout_marginBottom="16dp"
        android:paddingVertical="16dp"
        style="?android:attr/borderlessButtonStyle" />

    <!-- Botón Gestión de Reseñas -->
    <Button
        android:id="@+id/btnGestionResenas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestión de Reseñas"
        android:textSize="16sp"
        android:textColor="#000000"
        android:background="@drawable/button_outline"
        android:layout_marginBottom="16dp"
        android:paddingVertical="16dp"
        style="?android:attr/borderlessButtonStyle" />

    <!-- Botón Gestión de Videojuegos -->
    <Button
        android:id="@+id/btnGestionVideojuegos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestión de Videojuegos"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_filled"
        android:paddingVertical="16dp" />
    <!-- ⭐ NUEVO: Botón Cerrar Sesión -->
    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar Sesión"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336"
        android:layout_marginTop="32dp"
        android:paddingVertical="16dp" />

</LinearLayout>