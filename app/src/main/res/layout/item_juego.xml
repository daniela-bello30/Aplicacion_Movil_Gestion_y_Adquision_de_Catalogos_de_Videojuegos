<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="180dp"
    android:layout_height="340dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/white">

        <!-- Imagen del Juego -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <ImageView
                android:id="@+id/ivJuego"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/logo_dam"
                android:contentDescription="Imagen del juego" />

            <!-- Badge de Descuento -->
            <TextView
                android:id="@+id/tvDescuento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:background="@android:color/holo_red_dark"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="-80%"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Plataforma -->
            <TextView
                android:id="@+id/tvPlataforma"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@android:color/black"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="PS5"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Información del Juego -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#E0E0E0">

            <!-- Nombre del Juego -->
            <TextView
                android:id="@+id/tvNombreJuego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BATTLEFIELD 6"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <!-- Precio Original Tachado -->
            <TextView
                android:id="@+id/tvPrecioOriginal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/. 595.00"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray"
                android:visibility="gone" />

            <!-- Precio Final -->
            <TextView
                android:id="@+id/tvPrecio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/. 119.00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginBottom="8dp" />

            <!-- Botón Comprar -->
            <Button
                android:id="@+id/btnAnadirCarrito"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="🛒 Comprar"
                android:textSize="12sp"
                android:textColor="@android:color/black"
                android:backgroundTint="#FFA500"
                android:layout_marginBottom="4dp" />

            <!-- Botón Detalles -->
            <Button
                android:id="@+id/btnDetalles"
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:text="🔍 Ver Detalles"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@android:color/black" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>